generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ENUMS

enum Role {
  ADMIN
  USER
}

enum Platform {
  woocommerce
  shopify
  ebay
  magento
  bigcommerce
  prestashop
}

enum StoreStatus {
  ACTIVE
  INACTIVE
  ERROR
  PENDING_VERIFICATION
}



model User {
  id            Int      @id @default(autoincrement())
  firstName     String
  lastName      String
  email         String   @unique
  phone         String?
  password      String
  country       String?
  company       String?
  shipmentRange String?
  role          Role     @default(USER)
  isVerified    Boolean  @default(false)
  verificationToken String?
  createdAt     DateTime @default(now())
  PasswordResetToken PasswordResetToken[]
  Store              Store[]
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Store {
  id              Int      @id @default(autoincrement())
  userId          Int
  name            String
  platform        Platform  
  storeUrl        String?
  consumerKey     String?  // encrypted
  consumerSecret  String?  // encrypted
  status           StoreStatus   @default(ACTIVE)
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([platform])
  
}



